# Copy this file to .env and fill in YOUR Supabase project values.
# Get them from: https://supabase.com/dashboard → Project → Settings → API

SUPABASE_PROJECT_ID="your-project-id"
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_PUBLISHABLE_KEY="your-anon-or-publishable-key"

# Same values with VITE_ prefix (required for browser)
VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-or-publishable-key"

# Optional — only for trusted server-side admin operations
# SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
